# SkillSym AI - Environment Variables
# Copy this file to .env and fill in your values

# ─── DATABASE (Supabase - free) ───────────────────────────────────────────
# Get this from: supabase.com → your project → Settings → Database → Connection string
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT].supabase.co:5432/postgres

# ─── SECURITY ─────────────────────────────────────────────────────────────
# Make this a long random string - type anything random like: sk_abc123xyz789...
SECRET_KEY=change-this-to-something-very-long-and-random-12345

# ─── AI MODELS (Hugging Face - free) ─────────────────────────────────────
# Get free token from: huggingface.co → Settings → Access Tokens → New token
HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── FILE STORAGE (Cloudinary - free 25GB) ────────────────────────────────
# Get from: cloudinary.com → Dashboard
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_UPLOAD_PRESET=skillsym
CLOUDINARY_URL=cloudinary://api_key:api_secret@cloud_name

# ─── PAYMENTS (Stripe - free to set up, pay only on transactions) ─────────
# Get from: stripe.com → Developers → API Keys
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── YOUR WEBSITE URL ─────────────────────────────────────────────────────
# After deploying frontend on Vercel, put that URL here
FRONTEND_URL=https://skillsym.vercel.app
